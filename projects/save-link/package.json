{
  "name": "save-link",
  "version": "1.0.0",
  "description": "Event handlers for link saving and summary generation",
  "main": "src/infra/index.ts",
  "private": true,
  "exports": {
    "./save-link": {
      "types": "./dist/save-link/index.d.ts",
      "default": "./dist/save-link/index.js"
    },
    "./generate-summary": {
      "types": "./dist/generate-summary/index.d.ts",
      "default": "./dist/generate-summary/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "save-link": ["./dist/save-link/index.d.ts"],
      "generate-summary": ["./dist/generate-summary/index.d.ts"]
    }
  },
  "scripts": {
    "compile": "rm -rf dist && tsc",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\"",
    "check-infra": "if [ \"$CLAUDECODE\" = 1 ]; then echo 'Skipping check-infra in Claude Code environment'; else PULUMI_CONFIG_PASSPHRASE='' pulumi preview --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\"; fi",
    "check": "pnpm lint",
    "deploy": "PULUMI_CONFIG_PASSPHRASE='' pulumi up --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\"",
    "post-deploy": "echo 'No post-deploy steps'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.80.0",
    "@aws-sdk/client-dynamodb": "3.1001.0",
    "@aws-sdk/client-sqs": "3.1001.0",
    "@aws-sdk/lib-dynamodb": "3.1001.0",
    "@packages/hutch-event-bridge": "workspace:*",
    "@packages/hutch-logger": "workspace:*",
    "linkedom": "0.18.12",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@pulumi/aws": "7.20.0",
    "@pulumi/pulumi": "3.224.0",
    "@types/aws-lambda": "8.10.161",
    "@types/jest": "29.5.14",
    "concurrently": "9.2.1",
    "jest": "29.7.0",
    "typescript": "5.9.3"
  }
}
