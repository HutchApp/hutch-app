{
  "name": "browser-extension-core",
  "version": "1.0.0",
  "description": "Browser-agnostic core logic for Hutch browser extensions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./build": {
      "types": "./dist/build/build-extension.d.ts",
      "default": "./dist/build/build-extension.js"
    },
    "./e2e": {
      "types": "./dist/e2e/index.d.ts",
      "default": "./dist/e2e/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "e2e": ["dist/e2e/index.d.ts"]
    }
  },
  "private": true,
  "scripts": {
    "compile": "tsc",
    "check-unused-css": "node scripts/check-unused-css.js",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\" \"knip\" \"pnpm check-unused-css\"",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test:sequential": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --runInBand",
    "test-with-coverage": "pnpm compile && c8 node scripts/run-tests-with-coverage.js && node enforce-coverage.config.js",
    "check": "pnpm compile && pnpm lint && pnpm test-with-coverage"
  },
  "dependencies": {
    "esbuild": "0.25.4",
    "@packages/hutch-logger": "workspace:*",
    "js-base64": "3.7.8",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@packages/test-phase-runner": "workspace:*",
    "c8": "10.1.3",
    "concurrently": "9.2.1",
    "jest": "29.7.0",
    "@packages/check-unused-css": "workspace:*",
    "typescript": "5.9.3"
  }
}
