{
  "name": "web-embed",
  "targets": {
    "compile": {},
    "check": {
      "command": "pnpm lint && pnpm test-with-coverage",
      "options": { "cwd": "{projectRoot}" }
    },
    "deploy-infra": {
      "command": "PULUMI_CONFIG_PASSPHRASE='' pulumi up --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\" $([ \"$CI\" = true ] && echo --yes)",
      "options": { "cwd": "{projectRoot}" },
      "dependsOn": [
        "compile",
        { "projects": ["hutch"], "target": "deploy-infra" }
      ]
    },
    "post-deploy": {
      "command": "bash scripts/post-deploy.sh",
      "options": { "cwd": "{projectRoot}" }
    },
    "check-infra": {
      "command": "PULUMI_CONFIG_PASSPHRASE='' pulumi preview --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\"",
      "options": { "cwd": "{projectRoot}" },
      "dependsOn": [
        { "projects": ["hutch"], "target": "check-infra" }
      ]
    },
    "test": {},
    "test:e2e": {}
  }
}
