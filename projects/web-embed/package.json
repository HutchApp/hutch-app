{
  "name": "web-embed",
  "version": "1.0.0",
  "description": "Readplace embed kit — a save button publishers can drop onto any page",
  "private": true,
  "main": "src/infra/index.ts",
  "scripts": {
    "start": "NODE_ENV=production node dist/runtime/server.main.js",
    "dev": "PORT=3500 APP_ORIGIN=https://readplace.com EMBED_ORIGIN=http://localhost:3500/embed tsx watch src/runtime/server.main.ts",
    "dev:lambda": "tsx watch src/infra/lambda.ts",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test:e2e": "pnpm compile && E2E_PORT=3600 pnpm exec playwright test --config playwright.config.local-dev.ts",
    "test-with-coverage": "c8 node scripts/run-tests-with-coverage.js && node enforce-coverage.config.js",
    "compile": "rm -rf dist && tsc && node scripts/copy-static-assets.js",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\" \"knip\"",
    "check": "nx run web-embed:check",
    "check-infra": "PULUMI_CONFIG_PASSPHRASE='' pulumi preview --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\"",
    "deploy-infra": "PULUMI_CONFIG_PASSPHRASE='' pulumi up --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\" $([ \"$CI\" = true ] && echo --yes)",
    "post-deploy": "bash scripts/post-deploy.sh"
  },
  "dependencies": {
    "@packages/hutch-infra-components": "workspace:*",
    "express": "4.22.1",
    "handlebars": "4.7.8",
    "helmet": "8.1.0",
    "serverless-http": "4.0.0"
  },
  "devDependencies": {
    "@packages/test-phase-runner": "workspace:*",
    "@playwright/test": "1.58.2",
    "@pulumi/aws": "7.20.0",
    "@pulumi/pulumi": "3.224.0",
    "@types/aws-lambda": "8.10.161",
    "@types/express": "4.17.25",
    "@types/jest": "29.5.14",
    "@types/jsdom": "21.1.7",
    "@types/node": "22.15.21",
    "@types/supertest": "6.0.3",
    "c8": "10.1.3",
    "concurrently": "9.2.1",
    "jest": "29.7.0",
    "jsdom": "25.0.1",
    "supertest": "7.1.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
