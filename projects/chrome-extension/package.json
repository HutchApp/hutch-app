{
  "name": "chrome-extension",
  "version": "1.0.4",
  "description": "Hutch — Chrome browser extension for saving URLs to a reading list",
  "main": "src/infra/index.ts",
  "private": true,
  "exports": {
    "./s3-config": {
      "types": "./s3-config.d.ts",
      "default": "./s3-config.js"
    }
  },
  "scripts": {
    "compile": "tsc && HUTCH_SERVER_URL=https://hutch-app.com node scripts/build-extension.js && HUTCH_SERVER_URL=http://127.0.0.1:3000 node scripts/build-extension.js",
    "check-unused-css": "node scripts/check-unused-css.js",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\" \"knip\" \"pnpm check-unused-css\"",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --passWithNoTests",
    "test:sequential": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --runInBand --passWithNoTests",
    "test-with-coverage": "pnpm compile && c8 node scripts/run-tests-with-coverage.js && node enforce-coverage.config.js",
    "test:e2e": "HUTCH_SERVER_URL=http://127.0.0.1:3001 node scripts/build-extension.js && node --test dist/e2e/login-flow/run.e2e-local.js",
    "check-infra": "if [ \"$CLAUDECODE\" = 1 ]; then echo 'Skipping check-infra in Claude Code environment'; else PULUMI_CONFIG_PASSPHRASE='' pulumi preview --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\"; fi",
    "check": "nx run chrome-extension:check",
    "ext:run": "HUTCH_SERVER_URL=https://hutch-app.com node scripts/build-extension.js"
  },
  "dependencies": {
    "browser-extension-core": "workspace:*",
    "@packages/hutch-logger": "workspace:*",
    "webextension-polyfill": "0.12.0"
  },
  "devDependencies": {
    "@packages/test-phase-runner": "workspace:*",
    "@packages/hutch-test-app": "workspace:*",
    "@pulumi/aws": "7.20.0",
    "@pulumi/pulumi": "3.224.0",
    "@types/jest": "29.5.14",
    "@types/selenium-webdriver": "4.35.5",
    "@types/semver": "7.7.1",
    "c8": "10.1.3",
    "esbuild": "0.25.4",
    "concurrently": "9.2.1",
    "jest": "29.7.0",
    "@packages/check-unused-css": "workspace:*",
    "selenium-webdriver": "4.41.0",
    "semver": "7.7.4",
    "typescript": "5.9.3"
  }
}
