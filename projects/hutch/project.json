{
  "name": "hutch",
  "targets": {
    "compile": {
      "dependsOn": [
        { "projects": ["@packages/hutch-logger"], "target": "compile" }
      ]
    },
    "check": {
      "command": "pnpm lint && pnpm test-with-coverage && pnpm check-infra",
      "options": { "cwd": "{projectRoot}" }
    },
    "test": {
      "dependsOn": [
        { "projects": ["@packages/hutch-test-app"], "target": "compile" }
      ]
    },
    "test-integration": {
      "dependsOn": [
        { "projects": ["@packages/hutch-test-app"], "target": "compile" }
      ]
    }
  }
}
