{
  "extends": "../../tsconfig.config.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // Coverage needs inlineSources for accurate source mapping
    "inlineSources": true,
    // Incremental builds cache results for faster subsequent compilations
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
