{
  "name": "hutch",
  "version": "1.0.0",
  "description": "Hutch — read-it-later web application",
  "main": "src/infra/index.ts",
  "scripts": {
    "start": "NODE_ENV=production node dist/runtime/server.main.js",
    "dev": "npx --yes kill-port 35729 >/dev/null 2>&1; concurrently --kill-others \"livereload src --exts html,css,ts --wait 500\" \"LIVERELOAD=true tsx watch src/runtime/server.main.ts\"",
    "dev:lambda": "tsx watch src/infra/lambda.ts",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test:sequential": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --runInBand",
    "test-integration": "jest --testMatch='**/dist/**/*.integration.js' --testTimeout=30000",
    "test-integration:sequential": "jest --testMatch='**/dist/**/*.integration.js' --testTimeout=30000 --runInBand",
    "test:e2e": "pnpm compile && playwright test --config playwright.config.local-dev.ts",
    "test-with-coverage": "pnpm compile && c8 node scripts/run-tests-with-coverage.js && node enforce-coverage.config.js",
    "compile": "rm -rf dist && tsc && node scripts/copy-static-assets.js",
    "check-unused-css": "node scripts/check-unused-css.js",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\" \"knip\" \"pnpm check-unused-css\"",
    "check-infra": "if [ \"$CLAUDECODE\" = 1 ]; then echo 'Skipping check-infra in Claude Code environment'; else PULUMI_CONFIG_PASSPHRASE='' pulumi preview --stack prod; fi",
    "check": "pnpm compile && pnpm lint && pnpm test-with-coverage && pnpm check-infra",
    "deploy": "PULUMI_CONFIG_PASSPHRASE='' pulumi up --stack prod"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1001.0",
    "@aws-sdk/lib-dynamodb": "3.1001.0",
    "@mozilla/readability": "0.6.0",
    "@node-oauth/express-oauth-server": "4.1.5",
    "@node-oauth/oauth2-server": "5.2.1",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "express": "4.22.1",
    "firefox-extension": "workspace:*",
    "handlebars": "4.7.8",
    "helmet": "8.1.0",
    "hutch-logger": "workspace:*",
    "linkedom": "0.18.12",
    "resend": "6.9.3",
    "serverless-http": "4.0.0",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@pulumi/aws": "7.20.0",
    "@pulumi/pulumi": "3.224.0",
    "@types/aws-lambda": "8.10.161",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "4.17.25",
    "@types/jest": "29.5.14",
    "@types/jsdom": "21.1.7",
    "@types/node": "22.15.21",
    "@types/supertest": "6.0.3",
    "c8": "10.1.3",
    "concurrently": "9.2.1",
    "esbuild": "0.25.4",
    "jest": "29.7.0",
    "jsdom": "25.0.1",
    "livereload": "0.10.3",
    "purgecss": "8.0.0",
    "supertest": "7.1.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
