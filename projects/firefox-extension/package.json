{
  "name": "firefox-extension",
  "version": "1.0.0",
  "description": "Hutch — Firefox browser extension for saving URLs to a reading list",
  "private": true,
  "scripts": {
    "compile": "tsc",
    "check-unused-css": "node scripts/check-unused-css.js",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\" \"knip\" \"pnpm check-unused-css\"",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test:sequential": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --runInBand",
    "check": "pnpm lint && pnpm compile && pnpm test",
    "dist:extension": "node scripts/build-extension.js"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "concurrently": "9.2.1",
    "esbuild": "0.25.4",
    "jest": "29.7.0",
    "purgecss": "8.0.0",
    "typescript": "5.9.3"
  }
}
