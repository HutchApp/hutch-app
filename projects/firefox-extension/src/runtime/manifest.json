{
  "manifest_version": 2,
  "name": "Hutch",
  "version": "1.0.7",
  "description": "Save URLs to your reading list",
  "browser_specific_settings": {
    "gecko": {
      "id": "hutch-extension@hutch-app.com",
      "update_url": "https://hutch-extension-prod.s3.ap-southeast-2.amazonaws.com/updates.json",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "menus",
    "storage",
    "https://hutch-app.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.template.html",
    "default_title": "Hutch",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "64": "icons/icon-64.png"
    }
  },
  "background": {
    "scripts": [
      "background/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/shortcut.js"
      ],
      "run_at": "document_start"
    }
  ]
}
