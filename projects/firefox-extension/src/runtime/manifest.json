{
  "manifest_version": 2,
  "name": "Hutch",
  "version": "1.0.0",
  "description": "Save URLs to your reading list",
  "permissions": ["activeTab", "tabs"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.template.html",
    "default_title": "Hutch",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "64": "icons/icon-64.png"
    }
  },
  "background": {
    "scripts": ["background/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/shortcut.js"],
      "run_at": "document_start"
    }
  ],
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Ctrl+D"
      },
      "description": "Save current tab to reading list"
    }
  }
}
