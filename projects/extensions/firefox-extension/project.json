{
  "name": "firefox-extension",
  "targets": {
    "deploy": {
      "command": "PULUMI_CONFIG_PASSPHRASE='' pulumi up --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\" $([ \"$CI\" = true ] && echo --yes)",
      "options": { "cwd": "{projectRoot}" },
      "dependsOn": [
        { "projects": ["browser-extension-core"], "target": "compile" }
      ]
    },
    "compile": {
      "outputs": ["{projectRoot}/dist-extension-compiled", "{projectRoot}/dist-extension-files"]
    },
    "check": {
      "command": "pnpm lint && pnpm test-with-coverage",
      "options": { "cwd": "{projectRoot}" }
    }
  }
}
