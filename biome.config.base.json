{
	"$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"includes": [
			"**",
			"!**/dist/**",
			"!**/node_modules/**",
			"!**/*.js",
			"!**/*.mjs",
			"!**/*.html"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error"
			},
			"suspicious": {
				"noTemplateCurlyInString": "off"
			},
			"style": {
				"noCommonJs": "error"
			}
		}
	}
}
