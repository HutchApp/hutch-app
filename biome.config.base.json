{
	"$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"includes": [
			"**",
			"!**/dist/**",
			"!**/node_modules/**",
			"!**/*.js",
			"!**/*.mjs",
			"!**/*.html"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"useLiteralKeys": "error",
				"useOptionalChain": "error"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error"
			},
			"suspicious": {
				"noTemplateCurlyInString": "off",
				"noDocumentCookie": "error"
			},
			"style": {
				"noCommonJs": "error",
				"noNonNullAssertion": "error",
				"noDescendingSpecificity": "error",
				"useImportType": "error",
				"useTemplate": "error",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"paths": {
							"@aws-sdk/lib-dynamodb": "Import from @packages/hutch-storage-client instead — it forces schema-driven null handling (see projects/save-link/src/save-link/find-article-content.ts for the bug this prevents).",
							"@aws-sdk/client-dynamodb": "Import from @packages/hutch-storage-client instead — it forces schema-driven null handling."
						}
					}
				}
			}
		}
	}
}
