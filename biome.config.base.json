{
	"$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"includes": [
			"**",
			"!**/dist/**",
			"!**/node_modules/**",
			"!**/*.js",
			"!**/*.mjs",
			"!**/*.html"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error"
			},
			"suspicious": {
				"noTemplateCurlyInString": "off"
			},
			"style": {
				"noCommonJs": "error",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"paths": {
							"@aws-sdk/lib-dynamodb": "Import from @packages/hutch-storage-client instead — it forces schema-driven null handling (see projects/save-link/src/save-link/find-article-content.ts for the bug this prevents).",
							"@aws-sdk/client-dynamodb": "Import from @packages/hutch-storage-client instead — it forces schema-driven null handling."
						}
					}
				}
			}
		}
	},
	"overrides": [
		{
			"includes": [
				"**/src/runtime/app.ts",
				"**/src/runtime/providers/article-store/dynamodb-article-store.ts",
				"**/src/runtime/providers/auth/dynamodb-auth.ts",
				"**/src/runtime/providers/article-summary/dynamodb-summary-cache.ts",
				"**/src/runtime/providers/article-summary/dynamodb-summary-cache.test.ts",
				"**/src/runtime/providers/oauth/dynamodb-oauth-model.ts",
				"**/src/runtime/providers/password-reset/dynamodb-password-reset.ts",
				"**/src/runtime/providers/email-verification/dynamodb-email-verification.ts"
			],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": "off"
					}
				}
			}
		}
	]
}
