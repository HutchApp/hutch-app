{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/nx-schema.json",
  "tui": {
    "enabled": false
  },
  "plugins": [
    {
      "plugin": "nx/plugins/package-json"
    }
  ],
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/*.config.base.*"],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/jest.config.js"
    ]
  },
  "targetDefaults": {
    "test": {
      "inputs": ["default", "^production"],
      "cache": true
    },
    "compile": {
      "inputs": ["default", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^compile"],
      "cache": true
    },
    "lint": {
      "inputs": ["default"],
      "cache": true
    },
    "check": {
      "inputs": ["default", "^production"],
      "dependsOn": ["compile", "^compile"],
      "cache": true
    },
    "check-infra": {
      "inputs": ["production", "^production"],
      "dependsOn": ["^compile"],
      "cache": false
    },
    "deploy-infra": {
      "inputs": ["production", "^production"],
      "dependsOn": ["^compile"],
      "cache": false
    }
  },
  "defaultBase": "main"
}
