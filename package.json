    "jest": "29.7.0",
    "knip": "5.85.0",
    "minimatch": "10.1.1",
    "nx": "20.8.3",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  }
