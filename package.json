{
  "name": "hutch-app-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Hutch monorepo — read-it-later app",
  "scripts": {
    "test": "nx run-many --target=test --all",
    "compile": "nx run-many --target=compile --all",
