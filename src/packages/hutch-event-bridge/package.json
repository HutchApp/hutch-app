{
  "name": "@packages/hutch-event-bridge",
  "version": "1.0.0",
  "description": "Shared EventBridge provisioning and runtime helpers",
  "private": true,
  "exports": {
    "./infra": {
      "types": "./dist/infra/index.d.ts",
      "default": "./dist/infra/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "infra": ["./dist/infra/index.d.ts"],
      "runtime": ["./dist/runtime/index.d.ts"]
    }
  },
  "scripts": {
    "compile": "tsc",
    "lint": "tsc --project tsconfig.lint.json",
    "test": "echo 'No tests — infrastructure wrappers and type definitions only'"
  },
  "dependencies": {
    "@aws-sdk/client-eventbridge": "3.1001.0"
  },
  "devDependencies": {
    "@pulumi/aws": "7.20.0",
    "@pulumi/pulumi": "3.224.0",
    "typescript": "5.9.3"
  }
}
