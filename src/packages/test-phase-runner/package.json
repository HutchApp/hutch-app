{
  "name": "@packages/test-phase-runner",
  "version": "1.0.0",
  "description": "Reusable test phase runner for coverage-instrumented test suites",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "compile": "tsc",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\"",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test:sequential": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --runInBand",
    "check": "nx run @packages/test-phase-runner:check"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "jest": "29.7.0",
    "typescript": "5.9.3"
  }
}
