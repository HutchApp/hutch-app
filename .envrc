#!/bin/bash

# Automatically sets up your devbox environment whenever you cd into this
# directory via our direnv integration:

if [ -n "${DIRENV_IN_ENVRC:-}" ]; then
  eval "$(devbox generate direnv --print-envrc)"
fi

# check out https://www.jetify.com/docs/devbox/ide_configuration/direnv/
# for more details

export PULUMI_CONFIG_PASSPHRASE=''
export AWS_CONFIG_FILE="$PWD/.aws/config"

_pulumi_table() {
  grep "hutch:$1:" projects/hutch/Pulumi.prod.yaml | awk '{print $2}'
}
_pulumi_save_link() {
  grep "save-link:$1:" projects/save-link/Pulumi.prod.yaml | awk '{print $2}'
}
export DYNAMODB_ARTICLES_TABLE=$(_pulumi_table dynamodbArticlesTable)
export DYNAMODB_USER_ARTICLES_TABLE=$(_pulumi_table dynamodbUserArticlesTable)
export DYNAMODB_USERS_TABLE=$(_pulumi_table dynamodbUsersTable)
export DYNAMODB_SESSIONS_TABLE=$(_pulumi_table dynamodbSessionsTable)
export DYNAMODB_OAUTH_TABLE=$(_pulumi_table dynamodbOauthTable)
export DYNAMODB_VERIFICATION_TOKENS_TABLE=$(_pulumi_table dynamodbVerificationTokensTable)
export CONTENT_BUCKET_NAME=$(_pulumi_save_link contentBucketName)
export STATIC_BASE_URL=''
export EVENT_BUS_NAME='hutch-event-bus-4202fdd'
export ANALYTICS_SALT='local-dev-salt'

# Load secrets from .env, which is gitignored for local-only env vars
if [ -f "$PWD/.env" ]; then
  source "$PWD/.env"
fi